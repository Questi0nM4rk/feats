{
  "name": "@questi0nm4rk/feats",
  "version": "1.0.0",
  "description": "BDD/Gherkin test framework for Bun — feature testing with typed step definitions",
  "type": "module",
  "exports": {
    ".": {
      "import": "./src/feats.ts",
      "types": "./src/feats.ts"
    },
    "./plugin": {
      "import": "./src/plugin/bun-plugin.ts",
      "types": "./src/plugin/bun-plugin.ts"
    }
  },
  "scripts": {
    "test": "bun test",
    "test:watch": "bun test --watch",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src/ tests/",
    "lint:fix": "biome check --write src/ tests/",
    "build": "bun build src/feats.ts src/plugin/bun-plugin.ts --outdir dist --target bun",
    "build:types": "tsc --emitDeclarationOnly --outDir dist"
  },
  "dependencies": {
    "@cucumber/cucumber-expressions": "^19.0.0",
    "@cucumber/gherkin": "^37.0.0",
    "@cucumber/messages": "^32.0.0",
    "smol-toml": "^1.5.0",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.0",
    "@types/bun": "^1.3.0",
    "typescript": "^5.8.0"
  }
}
